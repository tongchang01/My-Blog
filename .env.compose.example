COMPOSE_PROJECT_NAME=myblog-v2
GHCR_OWNER=replace-with-github-owner
IMAGE_TAG=replace-with-full-commit-sha

BLOG_HOST=blog.example.com
WWW_HOST=www.example.com
ADMIN_HOST=admin.example.com
BLOG_ORIGIN=https://blog.example.com
ADMIN_ORIGIN=https://admin.example.com

MYSQL_DATABASE=myblog_v2
MYSQL_USER=myblog_v2
MYSQL_PASSWORD=replace-with-random-password
MYSQL_ROOT_PASSWORD=replace-with-random-root-password

MYBLOG_JWT_SECRET=replace-with-at-least-32-byte-secret
MYBLOG_STATS_HASH_SECRET=replace-with-random-secret
MYBLOG_STORAGE_TYPE=S3
MYBLOG_STORAGE_S3_REGION=ap-northeast-1
MYBLOG_STORAGE_S3_BUCKET=replace-with-s3-bucket
MYBLOG_STORAGE_S3_PUBLIC_BASE_URL=https://assets.example.com
MYBLOG_WEB_TRUSTED_PROXIES=172.28.0.0/16
MYBLOG_RESEND_ENABLED=false
