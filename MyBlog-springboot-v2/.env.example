MYBLOG_DATASOURCE_USERNAME="root"
MYBLOG_DATASOURCE_PASSWORD="<your-local-mysql-password>"
MYBLOG_JWT_SECRET="local-dev-jwt-secret-local-dev-jwt-secret-123456"
MYBLOG_STATS_HASH_SECRET="local-dev-stats-secret-local-dev-stats-secret-123456"

